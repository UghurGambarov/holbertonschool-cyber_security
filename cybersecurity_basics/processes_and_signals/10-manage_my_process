#!/usr/bin/env bash
#
PIDFILE="/tmp/my_process.pid"

case "$1" in
  start)
    ./manage_my_process &
    pid=$(pgrep -f manage_my_process | head -n 1)
    echo "$pid" > "$PIDFILE"
    echo "manage_my_process started"
    ;;

  stop)
    pkill -x manage_my_process
    sleep 1
    pkill -9 -f manage_my_process
    rm -f "$PIDFILE"
    echo "manage_my_process stopped"
    ;;

  restart)
    pkill -x manage_my_process
    rm -f "$PIDFILE"
    ./manage_my_process &
    pid=$(pgrep -f manage_my_process | head -n 1)
    echo "$pid" > "$PIDFILE"
    echo "manage_my_process restarted"
    ;;

  *)
    echo "Usage: manage_my_process {start|stop|restart}"
    ;;
esac
